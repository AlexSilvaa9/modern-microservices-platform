pipeline {
    agent any

    environment {
        SERVICE_NAME = 'order-service'
        DOCKER_REGISTRY = 'registry.midominio.com' // Cambiar por tu registry real
        DOCKER_IMAGE = "${DOCKER_REGISTRY}/${SERVICE_NAME}"
        SONAR_PROJECT_KEY = "microservices-${SERVICE_NAME}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Test & Build (Java)') {
            steps {
                dir("backend/services/${SERVICE_NAME}") {
                    // Compilar y correr pruebas unitarias
                    sh 'mvn clean test package -DskipTests=false'
                }
            }
            post {
                always {
                    junit "backend/services/${SERVICE_NAME}/target/surefire-reports/*.xml"
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir("backend/services/${SERVICE_NAME}") {
                    // Análisis hipotético de SonarQube
                    // Para que esto funcione, Jenkins debe tener configurado el servidor SonarQube
                    withSonarQubeEnv('SonarQubeServer') {
                        sh "mvn sonar:sonar -Dsonar.projectKey=${SONAR_PROJECT_KEY}"
                    }
                }
            }
        }

        stage('Docker Build & Push') {
            steps {
                dir("backend/services/${SERVICE_NAME}") {
                    script {
                        // Construimos la imagen y la tageamos con el hash del commit de Git
                        def commitHash = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                        env.IMAGE_TAG = commitHash
                        
                        sh "docker build -t ${DOCKER_IMAGE}:${IMAGE_TAG} -t ${DOCKER_IMAGE}:latest ."
                        
                        // Push al registry
                        // withCredentials([usernamePassword(credentialsId: 'docker-registry-creds', passwordVariable: 'DOCKER_PASS', usernameVariable: 'DOCKER_USER')]) {
                        //     sh "echo \$DOCKER_PASS | docker login ${DOCKER_REGISTRY} -u \$DOCKER_USER --password-stdin"
                        // }
                        sh "docker push ${DOCKER_IMAGE}:${IMAGE_TAG}"
                        sh "docker push ${DOCKER_IMAGE}:latest"
                    }
                }
            }
        }

        stage('Deploy to K8s') {
            steps {
                // Aquí aplicamos el cambio de imagen al deployment de Kubernetes correspondiente
                // Se asume que kubectl está configurado en el agente (ej. mediante Kubeconfig credentials)
                sh "kubectl set image deployment/${SERVICE_NAME} ${SERVICE_NAME}=${DOCKER_IMAGE}:${IMAGE_TAG} -n default"
                
                // Esperar a que el rollout termine para asegurar que el pod levantó bien
                sh "kubectl rollout status deployment/${SERVICE_NAME} -n default --timeout=120s"
            }
        }
    }

    post {
        always {
            // Limpieza de imágenes locales para liberar espacio
            sh "docker rmi ${DOCKER_IMAGE}:${IMAGE_TAG} || true"
        }
    }
}