pipeline {
    // Usamos un agente con Node.js disponible para compilar el frontend Angular
    agent {
        docker {
            image 'node:20-alpine'
            // Evitar problemas de permisos con el workspace
            args '-u root'
        }
    }

    environment {
        SERVICE_NAME = 'frontend'
        DOCKER_REGISTRY = 'registry.midominio.com' // Cambiar por tu registry real
        DOCKER_IMAGE = "${DOCKER_REGISTRY}/${SERVICE_NAME}"
        SONAR_PROJECT_KEY = "microservices-${SERVICE_NAME}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('frontend') {
                    sh 'npm ci'
                }
            }
        }

        stage('Lint & Test') {
            steps {
                dir('frontend') {
                    // sh 'npm run lint'
                    // sh 'npm run test:ci' // Ajustar al comando real de test (Karma/Jest)
                    echo "Hipotético: npm run lint & npm run test:ci"
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('frontend') {
                    // Hipotético análisis con Sonar Scanner
                    // withSonarQubeEnv('SonarQubeServer') {
                    //     sh 'npx sonar-scanner -Dsonar.projectKey=${SONAR_PROJECT_KEY}'
                    // }
                    echo "Hipotético: SonarQube analysis for Frontend"
                }
            }
        }

        stage('Build') {
            steps {
                dir('frontend') {
                    // Compilar para producción
                    sh 'npm run build -- --configuration production'
                }
            }
        }

        stage('Docker Build & Push') {
            agent any // Cambiamos de agente para poder usar docker CLI (requiere Docker daemon en el host)
            steps {
                dir('frontend') {
                    script {
                        def commitHash = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                        env.IMAGE_TAG = commitHash
                        
                        sh "docker build -t ${DOCKER_IMAGE}:${IMAGE_TAG} -t ${DOCKER_IMAGE}:latest ."
                        
                        // sh "docker push ${DOCKER_IMAGE}:${IMAGE_TAG}"
                        // sh "docker push ${DOCKER_IMAGE}:latest"
                        echo "Hipotético: Docker push for Frontend"
                    }
                }
            }
        }

        stage('Deploy to K8s') {
            agent any
            steps {
                // Aquí aplicamos el cambio de imagen al frontend
                // sh "kubectl set image deployment/${SERVICE_NAME} ${SERVICE_NAME}=${DOCKER_IMAGE}:${IMAGE_TAG} -n default"
                // sh "kubectl rollout status deployment/${SERVICE_NAME} -n default --timeout=120s"
                echo "Hipotético: Deploy to K8s for Frontend"
            }
        }
    }

    post {
        always {
            echo "Frontend pipeline finished."
        }
    }
}
